% Generated by hand for geoess
\name{geoess_spectrum}
\alias{geoess_spectrum}
\title{ESS Spectrum with Eigenvectors}
\description{
Returns eigenvalues and eigenvectors of the symmetrized operator
\eqn{M = I_1^{-1} I_\pi}.
}
\usage{
geoess_spectrum(I1, Ipi, symmetrize = TRUE)
}
\arguments{
\item{I1}{Numeric matrix. Fisher information per observation.}
\item{Ipi}{Numeric matrix. Prior curvature.}
\item{symmetrize}{Logical; if TRUE, symmetrize \eqn{M}.}
}
\value{
A list with \code{values}, \code{vectors}, and \code{M}.
}
\examples{
I1 <- diag(c(1, 2))
Ipi <- diag(c(4, 6))
geoess_spectrum(I1, Ipi)
}
