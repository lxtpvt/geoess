% Generated by hand for geoess
\name{geoess_hier_level}
\alias{geoess_hier_level}
\alias{geoess_hier_level_from_stan}
\alias{geoess_hier}
\title{Hierarchical ESS: Level-Specific}
\description{
Computes level-specific ESS for hierarchical models (theta per observation,
phi per group), with optional global averaging and a dispatcher to the
legacy between/borrowed method.
}
\usage{
geoess_hier_level(fit = NULL, draws = NULL, pars_theta = NULL, pars_phi = NULL,
  ref = c("prior_mean", "posterior_mean", "posterior_median", "posterior_mode", "custom"),
  theta_ref = NULL, phi_ref = NULL, Q = c("prior", "posterior", "custom"),
  Q_draws = NULL, method = c("trace", "eig", "dir"),
  conditional = list(enable = FALSE, idx_a = NULL, idx_b = NULL),
  Iunit_theta_fn = NULL, Iunit_phi_fn = NULL, Ipi_theta_fn = NULL,
  Ipi_phi_fn = NULL, Ipi_joint_fn = NULL, mix_joint = NULL, nsim = 2000,
  seed = 1, psd = c("none", "clip", "nearPD"), ...)

geoess_hier_level_from_stan(fit, pars_theta, pars_phi, group_structure = NULL,
  loglik_theta_i_fn = NULL, loglik_phi_group_fn = NULL, prior_draws = TRUE,
  posterior_draws = TRUE, mixfit = TRUE, unit_phi = c("group", "observation"), ...)

geoess_hier(method = c("level", "between_borrowed"), ...)
}
\arguments{
\item{fit, draws}{Stan fit or draws matrix.}
\item{pars_theta, pars_phi}{Parameter names for theta and phi blocks.}
\item{ref}{Reference point choice.}
\item{theta_ref, phi_ref}{Custom reference points.}
\item{Q, Q_draws}{Weighting distribution for global ESS.}
\item{method}{ESS method.}
\item{conditional}{Optional list controlling conditional ESS.}
\item{Iunit_theta_fn, Iunit_phi_fn}{Unit information functions or matrices.}
\item{Ipi_theta_fn, Ipi_phi_fn}{Prior curvature functions or matrices.}
\item{Ipi_joint_fn, mix_joint}{Joint curvature sources.}
\item{nsim, seed, psd}{Global ESS settings.}
\item{group_structure}{Group data list (Stan wrapper).}
\item{loglik_theta_i_fn, loglik_phi_group_fn}{Log-likelihood helpers (Stan wrapper).}
\item{...}{Passed to lower-level functions.}
}
\value{
Structured list with local and global ESS for theta and phi blocks.
}
