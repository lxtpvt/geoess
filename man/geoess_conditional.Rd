% Generated by hand for geoess
\name{geoess_conditional}
\alias{geoess_conditional}
\title{Conditional ESS via Schur Complement}
\description{
Computes conditional ESS for a component (or block) of parameters when
parameters are correlated, using Schur complements on \code{I1} and \code{Ipi}.
}
\usage{
geoess_conditional(I1, Ipi, idx_a, idx_b, method = c("trace", "scalar"),
  symmetrize = TRUE, solver = c("chol", "solve"))
}
\arguments{
\item{I1}{Numeric matrix. Fisher information per observation.}
\item{Ipi}{Numeric matrix. Prior curvature.}
\item{idx_a}{Integer indices for the target component/block.}
\item{idx_b}{Integer indices for the conditioning component/block.}
\item{method}{Character. "trace" or "scalar".}
\item{symmetrize}{Logical; if TRUE, symmetrize intermediate results.}
\item{solver}{Character. "chol" or "solve".}
}
\value{
A list with \code{I1_cond}, \code{Ipi_cond}, and \code{ess_cond}.
}
\examples{
I1 <- diag(c(2, 3))
Ipi <- matrix(c(4, 1, 1, 5), 2, 2)
geoess_conditional(I1, Ipi, idx_a = 1, idx_b = 2)
}
