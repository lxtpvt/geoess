\name{geoess_level_local}
\alias{geoess_level_local}
\alias{geoess_level_global}
\title{Level-Specific ESS (Local and Global)}
\description{
Compute level-specific ESS for theta or phi blocks, locally at a reference
point or globally under a weighting distribution.
}
\usage{
geoess_level_local(theta_ref, phi_ref, Iunit_fn, Ipi_fn,
  block = c("theta", "phi"), method = c("trace", "eig", "dir"),
  v = NULL, conditional = list(enable = FALSE, idx_a = NULL, idx_b = NULL),
  psd = c("none", "clip", "nearPD"), symmetrize = TRUE,
  solver = c("chol", "solve"), ...)

geoess_level_global(Q, idx_theta, idx_phi, block = c("theta", "phi"),
  Iunit_fn, Ipi_fn, method = c("trace", "eig", "dir"), v = NULL,
  conditional = list(enable = FALSE, idx_a = NULL, idx_b = NULL),
  nsim = 2000, seed = 1, weights = NULL, psd = c("none", "clip", "nearPD"),
  symmetrize = TRUE, ...)
}
\arguments{
\item{theta_ref, phi_ref}{Reference points for theta and phi blocks.}
\item{Iunit_fn}{Unit information function or matrix.}
\item{Ipi_fn}{Prior curvature function or matrix.}
\item{block}{Target block: "theta" or "phi".}
\item{method}{ESS method: "trace", "eig", or "dir".}
\item{v}{Direction for directional ESS.}
\item{conditional}{Optional list with \code{enable}, \code{idx_a}, \code{idx_b}.}
\item{Q}{Weighting distribution for global ESS.}
\item{idx_theta, idx_phi}{Indices for theta/phi blocks in draws.}
\item{nsim, seed, weights}{Sampling options for global ESS.}
\item{psd}{PSD handling for prior curvature.}
\item{...}{Passed to user-supplied functions.}
}
\value{
Local: a list with block matrices and ESS. Global: a \code{geoess_global_result}.
}
