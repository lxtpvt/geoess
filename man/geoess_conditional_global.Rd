% Generated by hand for geoess
\name{geoess_conditional_global}
\alias{geoess_conditional_global}
\title{Global Conditional ESS}
\description{
Computes the expectation of conditional ESS under a weighting distribution.
}
\usage{
geoess_conditional_global(Q, I1, Ipi, idx_a, idx_b, nsim = 2000,
  seed = 1, weights = NULL, psd = c("none", "clip", "nearPD"),
  return_samples = FALSE, ...)
}
\arguments{
\item{Q}{Distribution for \eqn{\theta}. See \code{geoess_global}.}
\item{I1}{Fisher information per observation.}
\item{Ipi}{Prior curvature.}
\item{idx_a}{Integer indices for the target component/block.}
\item{idx_b}{Integer indices for the conditioning component/block.}
\item{nsim}{Integer. Number of draws if sampling is needed.}
\item{seed}{Integer. Seed for reproducibility.}
\item{weights}{Optional weights aligned with draws.}
\item{psd}{Character. "none", "clip", or "nearPD" for Ipi adjustment.}
\item{return_samples}{Logical; if TRUE return per-draw ESS values.}
\item{...}{Passed to \code{I1} or \code{Ipi} if they are functions.}
}
\value{
A \code{geoess_global_result} object with conditional ESS summaries.
}
\examples{
set.seed(1)
draws <- matrix(rnorm(200), ncol = 2)
